---
import BaseLayout from '../layouts/BaseLayout.astro';
const allPosts = await Astro.glob('./blog/*.md');
const posts = allPosts.sort((a,b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
---
<BaseLayout title="QuartzLine Reviews" description="Solid entertainment analysis">
  <section class="crystal-hero"><h1>QuartzLine Reviews</h1><p>Solid entertainment analysis</p></section>
  <section class="crystal-grid">
    {posts.slice(0,12).map(post => (
      <article class="glass-card">
        {post.frontmatter.image && <img src={post.frontmatter.image} alt={post.frontmatter.title} loading="lazy" />}
        <div class="glass-body">
          <time>{new Date(post.frontmatter.date).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</time>
          <h3><a href={post.url}>{post.frontmatter.title}</a></h3>
          <p>{post.frontmatter.description?.slice(0,100)}</p>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
